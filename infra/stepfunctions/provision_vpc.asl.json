{
  "Comment": "VPC Provisioning workflow — for reference only. The authoritative definition is generated by AWS CDK in infra/stacks/vpc_provisioning_stack.py.",
  "StartAt": "Provision VPC and Subnets",
  "States": {
    "Provision VPC and Subnets": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:${AWS::Region}:${AWS::AccountId}:function:vpc-provision-task",
      "Payload": {
        "request_id.$": "$.request_id"
      },
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.SdkClientException",
            "Lambda.TooManyRequestsException"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 6,
          "BackoffRate": 2
        }
      ],
      "End": true,
      "ResultPath": null
    }
  },
  "TimeoutSeconds": 600
}
