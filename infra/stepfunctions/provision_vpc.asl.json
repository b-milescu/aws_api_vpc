{
  "Comment": "VPC Provisioning workflow — for reference only. The authoritative definition is generated by AWS CDK in infra/stacks/vpc_provisioning_stack.py.",
  "StartAt": "Provision VPC and Subnets",
  "States": {
    "Provision VPC and Subnets": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "arn:aws:lambda:${AWS::Region}:${AWS::AccountId}:function:vpc-provision-task",
        "Payload": {
          "request_id.$": "$.request_id"
        }
      },
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.SdkClientException",
            "Lambda.TooManyRequestsException"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 6,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "Handle Provision Failure"
        }
      ],
      "ResultPath": null,
      "End": true
    },
    "Handle Provision Failure": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "arn:aws:lambda:${AWS::Region}:${AWS::AccountId}:function:vpc-sfn-failure-handler",
        "Payload": {
          "error.$": "$.Error",
          "cause.$": "$.Cause",
          "input.$": "$$.Execution.Input"
        }
      },
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.SdkClientException",
            "Lambda.TooManyRequestsException"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 6,
          "BackoffRate": 2
        }
      ],
      "ResultPath": null,
      "End": true
    }
  },
  "TimeoutSeconds": 600
}
